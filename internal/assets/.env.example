# ── Application Settings ─────────────────────────────────────────────
APP_ENV=production          # Environment type: 'development' or 'production'
APP_PORT=8181               # Port where the backend app will run
APP_SECRET_KEY=             # App secret key (auto-generated by init-env.sh)
API_DOCS_ENABLED=false      # Enable API documentation (Swagger UI)
TIDEFLY_ENCRYPTION_KEY=     # Secret key for Encryption (auto-generated)

# ── Database / Postgres ─────────────────────────────────────────────
DATABASE_URL=               # Full Postgres connection URL (auto-set by init-env.sh)
POSTGRES_USER=tidefly       # Postgres username
POSTGRES_PASSWORD=          # Postgres password (auto-generated)
POSTGRES_DB=tidefly         # Postgres database name

# ── Cache / Redis ───────────────────────────────────────────────────
REDIS_URL=                  # Full Redis connection URL (auto-set by init-env.sh)
REDIS_ADDR=127.0.0.1:6379   # Redis host and port (use Docker hostname in prod)
REDIS_USER=tidefly          # Redis username
REDIS_PASSWORD=             # Redis password (auto-generated)

# ── Session / Cookie Secrets, Agen Encryption Key ───────────────────────────────────────
JWT_SECRET=                 # Secret key for signing JWT tokens (auto-generated)

# ── Runtime / Docker ───────────────────────────────────────────────
RUNTIME_TYPE=docker         # Runtime type (docker or local)
DOCKER_SOCK=/var/run/docker.sock  # Path to Docker socket
PODMAN_SOCK=/run/user/1000/podman/podman.sock # Path to Podman socket (if using Podman)

# ── Email / SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.example.com  # SMTP server host
SMTP_PORT=465               # SMTP server port
SMTP_USER=                  # SMTP username
SMTP_PASSWORD=              # SMTP password
SMTP_FROM=noreply@example.com # Default sender email
SMTP_TLS=tls                # TLS mode for SMTP (tls/ssl)

# ── Templates ──────────────────────────────────────────────────────
TEMPLATES_DIR=../../tidefly-templates # Path to templates (GitHub in prod, local in dev)

# ── Caddy / Reverse Proxy ────────────────────────────────────────
CADDY_ENABLED=true         # Enable Traefik routing
CADDY_ADMIN_URL=http://127.0.0.1:2019
CADDY_BASE_DOMAIN=apps.example.com # Base domain for routing
CADDY_ACME_EMAIL=admin@example.com # Email for Let's Encrypt certificates
CADDY_ACME_STAGING=false   # Use staging CA (true for testing)
CADDY_FORCE_HTTPS=true     # Force HTTPS redirection
CADDY_INTERNAL_TLS=true       # Traefik logging level

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info               # App log level
LOG_DB_LEVEL=warn            # DB query logging level
LOG_SLOW_QUERY_MS=500        # Threshold for slow query logging (ms)

# ── Logging ───────────────────────────────────────────────────────
LOGWATCHER_ENABLED=true               # Enable log watcher for real-time log streaming
LOGWATCHER_POLL_INTERVAL=15           # Polling interval for log watcher (seconds)
LOGWATCHER_TAIL_LINES=50              # Number of lines to show when tailing logs
LOGWATCHER_MAX_MESSAGE_LEN=3000       # Max length of log messages in log watcher
LOGWATCHER_DEDUP_WINDOW=2             # Time window for deduplication in log watcher (m)

# ── Scheduled Jobs / Cleanup ──────────────────────────────────────
JOBS_ENABLED=true                    # Enable background jobs
JOBS_CLEANUP_CRON='0 3 * * *'       # Cron schedule for cleanup
JOBS_CLEANUP_OLDER_THAN=24h         # Remove containers/images older than this
JOBS_CLEANUP_STOPPED_CONTAINERS=true
JOBS_CLEANUP_DANGLING_IMAGES=true
JOBS_CLEANUP_UNUSED_VOLUMES=false
JOBS_LOG_RETENTION_CRON='0 4 * * *' # Cron for log retention
JOBS_LOG_RETENTION_DAYS=30          # Keep logs for this many days
JOBS_AUDIT_RETENTION_DAYS=90        # Keep audit logs for this many days
JOBS_NOTIFICATION_RETENTION_DAYS=30 # Keep notifications for this many days
JOBS_HEALTH_CHECK_CRON='*/5 * * * *' # Cron schedule for health checks
JOBS_CONCURRENCY=5                  # Number of concurrent jobs